{
  "name": "@madebymadhouse/asciigen",
  "version": "0.1.0",
  "description": "Convert images and videos to ASCII art from the terminal.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "asciigen": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --external:sharp --external:commander --outfile=dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "sharp": "^0.32.0"
  },
  "devDependencies": {
    "@asciigen/engine": "*",
    "esbuild": "^0.21.5"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebymadhouse/asciigen.git",
    "directory": "packages/cli"
  },
  "license": "MIT"
}
